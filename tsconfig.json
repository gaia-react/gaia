{
  "compilerOptions": {
    "esModuleInterop": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": ["DOM", "ESNext"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "noUncheckedSideEffectImports": true,
    "paths": {
      "~/*": ["./app/*"],
      "test/*": ["./test/*"]
    },
    "resolveJsonModule": true,
    "rootDirs": [".", "./.react-router/types"],
    "skipLibCheck": true,
    "stableTypeOrdering": true,
    "strict": true,
    "target": "ES2022",
    "types": ["@react-router/node", "vite/client"]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/.server/**/*.ts",
    "**/.server/**/*.tsx",
    "**/.client/**/*.ts",
    "**/.client/**/*.tsx",
    ".react-router/types/**/*",
    ".storybook/**/*",
    ".playwright/**/*"
  ],
  "exclude": ["node_modules", "build", "coverage", "storybook-static"]
}
