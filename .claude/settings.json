{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/wiki-session-start.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/wiki-session-stop.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/wiki-squash-autocommits.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/wiki-drift-check.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/wiki-recompact-inject.sh"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/wiki-recompact-sentinel.sh"
          }
        ]
      }
    ],
    "UserPromptExpansion": [
      {
        "matcher": "init",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/intercept-init.sh"
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .gaia/scripts/create-worktree.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-env-write.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/block-eslint-config-edit.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/block-lockfile-edit.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/block-secrets-write.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/block-vitest-globals-tsconfig.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/check-i18n-strings.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/check-story-exists.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-bare-test.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/block-main-destructive-git.sh",
            "statusMessage": "Checking main-branch protection…"
          },
          {
            "type": "command",
            "command": ".claude/hooks/block-no-verify.sh",
            "statusMessage": "Checking commit-floor bypass…"
          },
          {
            "type": "command",
            "command": ".claude/hooks/red-verify-commit-check.sh",
            "statusMessage": "Checking RED-before-GREEN gate…"
          },
          {
            "type": "command",
            "command": ".claude/hooks/block-rm-rf.sh",
            "statusMessage": "Checking rm -rf safety…"
          },
          {
            "type": "command",
            "command": ".claude/hooks/pr-merge-audit-check.sh",
            "statusMessage": "Checking PR-merge audit gate…"
          },
          {
            "type": "command",
            "command": ".claude/hooks/token-tally-git-op.sh",
            "statusMessage": "Recording execute-phase token tally…"
          },
          {
            "type": "command",
            "command": ".claude/hooks/worthiness-presence-check.sh",
            "statusMessage": "Checking worthiness presence gate…"
          },
          {
            "type": "command",
            "command": ".claude/hooks/audit-disposition-check.sh",
            "statusMessage": "Checking audit disposition ledger…"
          },
          {
            "type": "command",
            "command": ".claude/hooks/serena-code-search-guard.sh",
            "statusMessage": "Checking Serena code-search routing…"
          }
        ]
      },
      {
        "matcher": "Grep",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/serena-code-search-guard.sh",
            "statusMessage": "Checking Serena code-search routing…"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/wiki-commit-nudge.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/token-rollup-merge.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/capture-red-observations.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/debt-sentinel-touch.sh"
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/telemetry-task-postuse.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(bash .gaia/scripts/plan-archive.sh:*)",
      "Bash(corepack enable pnpm)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git merge-base:*)",
      "Bash(git rev-parse:*)",
      "Bash(git show:*)",
      "Bash(git stash:*)",
      "Bash(git status:*)",
      "Bash(git switch:*)",
      "Bash(git symbolic-ref:*)",
      "Bash(git worktree *)",
      "Bash(mkdir -p .gaia/local/audit)",
      "Bash(mkdir -p .gaia/local/plans)",
      "Bash(pnpm build:*)",
      "Bash(pnpm dev:*)",
      "Bash(pnpm format)",
      "Bash(pnpm install:*)",
      "Bash(pnpm lint)",
      "Bash(pnpm lint-dry)",
      "Bash(pnpm ls:*)",
      "Bash(pnpm outdated:*)",
      "Bash(pnpm pw-ui:*)",
      "Bash(pnpm pw:*)",
      "Bash(pnpm remove:*)",
      "Bash(pnpm storybook:*)",
      "Bash(pnpm stylelint)",
      "Bash(pnpm test:ci)",
      "Bash(pnpm test:ci:*)",
      "Bash(pnpm typecheck)",
      "Bash(pnpm typecheck:*)",
      "Bash(rm -f .gaia/cache/*)",
      "Bash(rm -f .gaia/local/handoff/HANDOFF-*.md)",
      "Bash(rm -rf .gaia/local/plans/*)",
      "Bash(rm -rf .gaia/local/specs/*)",
      "Bash(rm .gaia/local/handoff/HANDOFF-*.md)",
      "Edit(.claude/agents/**)",
      "Edit(.claude/commands/**)",
      "Edit(.claude/instructions/**)",
      "Edit(.claude/rules/**)",
      "Edit(.claude/skills/**)",
      "Edit(.gaia/**)",
      "Edit(.playwright/**)",
      "Edit(.storybook/**)",
      "Edit(CHANGELOG.md)",
      "Edit(app/**)",
      "Edit(public/**)",
      "Edit(test/**)",
      "Edit(wiki/**)",
      "WebFetch(domain:context7.com)",
      "Write(.gaia/local/audit/**)",
      "Write(.gaia/local/handoff/**)",
      "Write(.gaia/local/plans/**)",
      "Write(.gaia/local/specs/**)"
    ],
    "deny": [
      "Bash(git push --force-with-lease *main*)",
      "Bash(git push --force-with-lease *master*)",
      "Bash(git reset --hard HEAD~*)",
      "Edit(.env)",
      "Edit(.husky/_/**)",
      "Edit(pnpm-lock.yaml)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(**/*credential*)",
      "Read(**/secrets/*)",
      "Read(.env)",
      "Write(.env)",
      "Write(pnpm-lock.yaml)"
    ]
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true
  },
  "statusLine": {
    "type": "command",
    "command": "bash .gaia/statusline/gaia-statusline.sh"
  }
}
