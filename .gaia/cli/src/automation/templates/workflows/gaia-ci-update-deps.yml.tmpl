{{> partials/header }}
permissions:
  contents: write
  pull-requests: write
  issues: write
  id-token: write

{{> partials/concurrency }}
{{> partials/auth-env }}
jobs:
  run:
    runs-on: ubuntu-latest
    timeout-minutes: 60
    outputs:
      wave_b_matrix: ${{ steps.emit_updates.outputs.wave_b_matrix }}
      wave_b_count: ${{ steps.emit_updates.outputs.wave_b_count }}
      decision: ${{ steps.pre_run.outputs.decision }}
    steps:
{{> partials/checkout-setup }}
{{> partials/pre-run-skip }}
{{> partials/quality-gate }}
{{#enable_major_bump_split}}
      - name: Emit update-deps plan
        id: emit_updates
        if: steps.pre_run.outputs.decision == 'run'
        # `update-deps run --emit-updates` enumerates outdated packages,
        # applies the ESLint 9.x cap and override audit, and writes a
        # JSON plan with two waves: wave_a (minor/patch, batched) and
        # wave_b (one entry per major-bump group).
        run: |
          set -euo pipefail
          updates_file="${RUNNER_TEMP}/update-deps/updates.json"
          mkdir -p "$(dirname "$updates_file")"
          .gaia/cli/gaia update-deps run --emit-updates "$updates_file"
          echo "updates_file=$updates_file" >> "$GITHUB_OUTPUT"
          # Build the wave-B matrix payload: `{"include": [{group: "..."}, ...]}`.
          # The fan-out job's `strategy.matrix` consumes this verbatim.
          wave_b_groups=$(jq -c '[.wave_b[] | {group: .group}]' "$updates_file")
          wave_b_count=$(jq -r '.wave_b | length' "$updates_file")
          echo "wave_b_count=$wave_b_count" >> "$GITHUB_OUTPUT"
          echo "wave_b_matrix={\"include\":$wave_b_groups}" >> "$GITHUB_OUTPUT"
          # Wave-A package count drives the wave-A apply gate below.
          wave_a_count=$(jq -r '.wave_a | length' "$updates_file")
          echo "wave_a_count=$wave_a_count" >> "$GITHUB_OUTPUT"

      - name: Run /update-deps for wave A (minor/patch)
        id: wave_a
        if: |
          steps.pre_run.outputs.decision == 'run' &&
          steps.emit_updates.outputs.wave_a_count != '0'
        # Wave-A is the batched minor/patch path. The plan file scopes
        # the work; Claude executes the `/update-deps` skill against
        # only those entries, runs the quality gate, and leaves the
        # working tree dirty for the auto-merge partial to commit.
        env:
          UPDATES_FILE: ${{ steps.emit_updates.outputs.updates_file }}
          RUN_COST_DOLLARS: "0"  # placeholder; overwritten by claude-code-action wrapper
        uses: anthropics/claude-code-action@63322d7b2bc79e7b621b89f41b53ceb8e5a5d314 # v1.0
        with:
          claude_code_oauth_token: ${{ secrets.CLAUDE_CODE_OAUTH_TOKEN }}
          prompt: |
            Apply the `/update-deps` skill scoped to **wave A only**:
            the minor and patch bumps batched into a single install. The
            plan emitted by `gaia update-deps run --emit-updates` is at
            `${{ steps.emit_updates.outputs.updates_file }}`; read its
            `wave_a` array to determine what to install.

            Procedure:

            1. Read `${{ steps.emit_updates.outputs.updates_file }}`.
               Iterate `wave_a` entries. For each, build a `pnpm add`
               argument respecting `is_pinned`: pinned → exact version,
               otherwise → `^<latest>`.
            2. Run a single `pnpm add ...` with all entries combined.
            3. Run `pnpm ls 2>&1`. On peer-dep error, attempt one
               targeted `overrides:` fix in `pnpm-workspace.yaml`
               (e.g. `parent>child`), then `pnpm install` again. If
               still failing, revert the offending package(s) and
               proceed with the rest.
            4. Run the quality gate exactly: `pnpm typecheck`,
               `pnpm lint`, `pnpm test --run`, `pnpm pw`, `pnpm build`.
               If the gate fails, revert the entire wave-A batch and
               exit non-zero; the auto-merge partial will see no
               changes and skip the PR.

            Wave-B (per-group major bumps) is handled in a separate
            matrix job. Do NOT attempt to apply any wave-B group here;
            the plan file's `wave_b` array is informational only for
            this step.

            Do not push to remotes. The workflow's auto-merge partial
            commits the diff and opens the PR.
          claude_args: |
            --max-turns 60
            --allowedTools Bash,Edit,Write,Read
            --disallowedTools WebFetch,WebSearch
{{/enable_major_bump_split}}
{{> partials/auto-merge }}
{{> partials/cost-accounting }}

{{#enable_major_bump_split}}
  wave_b:
    needs: run
    if: |
      needs.run.outputs.decision == 'run' &&
      needs.run.outputs.wave_b_count != '0' &&
      needs.run.outputs.wave_b_matrix != ''
    runs-on: ubuntu-latest
    timeout-minutes: 90
    permissions:
      contents: write
      pull-requests: write
      issues: write
      id-token: write
    strategy:
      fail-fast: false
      matrix: ${{ fromJson(needs.run.outputs.wave_b_matrix) }}
    steps:
{{> partials/checkout-setup }}
      - name: Create per-group branch
        id: branch
        env:
          GROUP: ${{ matrix.group }}
        run: |
          set -euo pipefail
          branch="gaia-ci/{{tool_id}}/wave-b/${GROUP}-$(date -u +%Y%m%d-%H%M%S)"
          git fetch origin "${{ github.event.repository.default_branch }}"
          git checkout -B "$branch" "origin/${{ github.event.repository.default_branch }}"
          git config user.name 'github-actions[bot]'
          git config user.email 'github-actions[bot]@users.noreply.github.com'
          echo "name=$branch" >> "$GITHUB_OUTPUT"

      - name: Run /update-deps for wave B group
        id: wave_b_apply
        # Per-group wave-B execution. Claude reads the migration guide,
        # runs `pnpm add` (or `pnpm dlx storybook@latest upgrade` for
        # the storybook group), applies code-affecting changes inside
        # `app/`, `test/`, and root config files, and runs the quality
        # gate. Web tools enabled so the migration guide is fetchable.
        env:
          GROUP: ${{ matrix.group }}
          RUN_COST_DOLLARS: "0"  # placeholder; overwritten by claude-code-action wrapper
        uses: anthropics/claude-code-action@63322d7b2bc79e7b621b89f41b53ceb8e5a5d314 # v1.0
        with:
          claude_code_oauth_token: ${{ secrets.CLAUDE_CODE_OAUTH_TOKEN }}
          prompt: |
            Run `/update-deps --scope ${{ matrix.group }}`.

            This is a wave-B per-group major-bump run. Apply the
            `--scope` flag as defined in the skill: skip Phase 0, 1,
            and 3; execute Phase 4/5 for the named group's members in
            root `package.json` only; run the quality gate.

            If unfixable after a reasonable attempt, revert the group
            and exit non-zero so the workflow opens no PR for this
            group.

            Do not push to remotes. The workflow commits and opens the
            per-group PR after this step.
          claude_args: |
            --max-turns 100
            --allowedTools Bash,Edit,Write,Read,WebFetch
            --disallowedTools WebSearch

      - name: Open wave-B group PR
        if: success()
        env:
          GROUP: ${{ matrix.group }}
          BRANCH: ${{ steps.branch.outputs.name }}
        run: |
          set -euo pipefail
          if [ -z "$(git status --porcelain)" ]; then
            echo "no changes for ${GROUP}; nothing to PR"
            exit 0
          fi
          git add -A
          git commit -m "chore({{tool_id}}): wave-B major bump: ${GROUP}"
          git push origin "$BRANCH"
          pr_url=$(gh pr create \
            --title "chore({{tool_id}}): wave-B major bump: ${GROUP}" \
            --body "Per-group major-bump PR opened by GAIA CI ({{workflow_name}}). Group: \`${GROUP}\`. Review the migration carefully; wave-B PRs are not auto-merged." \
            --label gaia-ci,{{needs_human_review_label}} \
            --head "$BRANCH" \
            --base "${{ github.event.repository.default_branch }}")
          echo "wave-B PR opened: $pr_url"

      - name: Wave-B cost accounting
        if: always()
        env:
          GAIA_CI_COST_CEILING: '{{cost_ceiling_dollars}}'
          GROUP: ${{ matrix.group }}
        run: |
          set -euo pipefail
          cost="${RUN_COST_DOLLARS:-0}"
          .gaia/cli/gaia automation record-run \
            {{tool_id}} \
            --sha "$(git rev-parse HEAD)" \
            --trigger cron \
            --cost "$cost"
          overage=$(.gaia/cli/gaia automation read-state {{tool_id}} --json \
            | jq -r '.cost_overage // false')
          if [ "$overage" = "true" ]; then
            gh issue create \
              --title "[GAIA CI] {{workflow_name}} wave-B cost overage (${GROUP}): \$${cost}" \
              --label gaia-ci,priority:high \
              --body "{{workflow_name}} wave-B run for group \`${GROUP}\` reported \$${cost} (ceiling: \$${GAIA_CI_COST_CEILING}). Next run for {{tool_id}} is suppressed until cleared via 'gaia automation clear-overage {{tool_id}}'."
          fi
{{/enable_major_bump_split}}
