      # Auto-merge partial. Gated on `enable_auto_merge` so the
      # stale-branches workflow (which doesn't open a PR) emits no
      # merge invocation in its rendered YAML.
{{#enable_auto_merge}}
      - name: Open and auto-merge gaia-ci PR
        if: steps.pre_run.outputs.decision == 'run' && success()
        run: |
          set -euo pipefail
          branch="gaia-ci/{{tool_id}}/$(date -u +%Y%m%d-%H%M%S)"
          git checkout -b "$branch"
          if [ -z "$(git status --porcelain)" ]; then
            echo "no changes; nothing to PR"
            exit 0
          fi
          git add -A
          git commit -m "chore({{tool_id}}): GAIA CI run"
          git push origin "$branch"
          pr_url=$(gh pr create \
            --title "chore({{tool_id}}): GAIA CI run" \
            --body "Generated by GAIA CI ({{workflow_name}})." \
            --label gaia-ci \
            --head "$branch" \
            --base "${{ github.event.repository.default_branch }}")
          pr_number=$(printf '%s' "$pr_url" | grep -oE '[0-9]+$')
{{#enable_diff_size_check}}
          # Wiki diff-size sanity check: if more than 25% of wiki bytes
          # changed, label `needs-human-review` and skip auto-merge.
          if [ "$(node .gaia/cli/dist/index.js wiki diff-size --threshold-pct 25)" = "exceeded" ]; then
            gh pr edit "$pr_number" --add-label needs-human-review
            echo "diff-size > 25%; holding for human review"
            exit 0
          fi
{{/enable_diff_size_check}}
          gh pr merge "$pr_number" --auto --squash
{{/enable_auto_merge}}
