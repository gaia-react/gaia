{
  "$schema": "https://react.doctor/schema/config.json",
  "ignore": {
    // Generated build output is not source; never scan it.
    // Drops the artifact-env-leak finding on build/server/index.js.map.
    "files": ["build/**"],
    "overrides": [
      {
        // .gaia/cli is maintainer-run CLI tooling. "Caller input" is CLI
        // flags typed by an operator who already has a shell, not web/request
        // data, so path-traversal-risk does not apply. js-length-check-first
        // is a perf micro-opt that does not matter for one-shot CLI commands.
        "files": [".gaia/cli/**"],
        "rules": [
          "react-doctor/path-traversal-risk",
          "react-doctor/js-length-check-first"
        ]
      },
      {
        // The Chromatic/GitHub tokens are scoped to the Run Chromatic step via
        // `with:`; they are not in the environment during `pnpm install`, so a
        // lifecycle script cannot read them.
        "files": [".github/workflows/**"],
        "rules": ["react-doctor/build-pipeline-secret-boundary"]
      }
    ]
  },
  "categories": {
    // knip is this project's dead-code oracle (see .claude/rules/knip.md);
    // do not double-report dead code from react-doctor's deslop family.
    "Maintainability": "off"
  }
}
